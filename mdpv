#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF' >&2
Usage: mdpv <markdown-file>

Starts the inline-discussion server for the given file and opens it in
the default browser. The server runs in the foreground until Ctrl+C.
EOF
  exit 1
}

[[ $# -ge 1 ]] || usage
case "$1" in -h|--help) usage ;; esac

resolve_command() {
  local command_path target
  command_path="$(command -v "$1" || true)"
  [[ -n "$command_path" ]] || return 1

  while [[ -L "$command_path" ]]; do
    target="$(readlink "$command_path")"
    if [[ "$target" == /* ]]; then
      command_path="$target"
    else
      command_path="$(cd -P "$(dirname "$command_path")" >/dev/null && cd -P "$(dirname "$target")" >/dev/null && pwd)/$(basename "$target")"
    fi
  done

  printf '%s\n' "$command_path"
}

doc="$1"
[[ -f "$doc" ]] || { echo "mdpv: file not found: $doc" >&2; exit 2; }

LAUNCH="$(resolve_command inline-discussion || true)"
[[ -n "$LAUNCH" ]] || { echo "mdpv: inline-discussion not found in PATH" >&2; exit 3; }

session_dir="$(mktemp -d "${TMPDIR:-/tmp}/mdpv.XXXXXX")"

cleanup() {
  if [[ -f "$session_dir/server.pid" ]]; then
    local pid
    pid="$(cat "$session_dir/server.pid" 2>/dev/null || true)"
    [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
  fi
  rm -rf "$session_dir"
}
trap cleanup INT TERM EXIT

url="$("$LAUNCH" start --doc "$doc" --session-dir "$session_dir")"
[[ -n "$url" ]] || { echo "mdpv: no URL emitted by server" >&2; exit 4; }

echo "$url"
open "$url" >/dev/null 2>&1 || true

"$LAUNCH" wait --session-dir "$session_dir"
