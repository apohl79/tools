{
  "name": "markdown-preview-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "node --import tsx/esm --test --test-concurrency=1 'test/*.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.139",
    "marked": "12.0.2",
    "highlight.js": "11.9.0",
    "isomorphic-dompurify": "2.9.0",
    "jsdom": "24.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.6",
    "@types/node": "20.19.41",
    "dompurify": "3.0.9",
    "esbuild": "0.28.0",
    "tsx": "4.7.2",
    "typescript": "5.4.5"
  }
}
